# Environment variables for Memo Structurizer Backend

# GitHub Configuration (Optional - for GitHub integration)
# Generate a token at: https://github.com/settings/tokens
# Scopes needed: repo (full control of private repositories)
# WARNING: Never commit this file with actual tokens!
GITHUB_TOKEN=your_github_token_here

# GitHub repository for saving memos
# Format: owner/repo (e.g., Yuka-Mats/memo-structurizer)
GITHUB_REPO=

# Base directory for saving memos locally
# Default: ~/Documents/my-knowledge
BASE_DIRECTORY=${HOME}/Documents/my-knowledge

# Application
DEBUG=True
APP_NAME=Memo Structurizer API
